# ShelfWise Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub -- it contains secrets

# Microsoft Foundry / Azure OpenAI Settings
# Run setup-azure-openai.ps1 to auto-generate these, or create Azure OpenAI manually
FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4.1-mini/chat/completions?api-version=2024-02-01
FOUNDRY_API_KEY=your-azure-openai-api-key
FOUNDRY_MODEL=gpt-4.1-mini

# Optional: Brave Search API (for enhanced web scraping)
# Get a free key at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=your-brave-api-key

# Optional: Google Custom Search JSON API (for Google search results)
# Get a free key at: https://developers.google.com/custom-search/v1/overview
# You also need a Programmable Search Engine ID
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-programmable-search-engine-id