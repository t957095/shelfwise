      "name": "Amazon Product API",
      "type": "api",
      "weight": 0.60,
      "url_template": "https://api.amazon.com/products/{upc}",
      "method": "GET",
      "timeout": 10,
      "requires_auth": "AMAZON_API_KEY",
      "extract": {
        "name": ["product", "title"],
        "brand": ["product", "brand"],
        "category": ["product", "category"],
        "description": ["product", "description"],
        "image_urls": ["product", "images"],
        "attributes": ["product", "attributes"]
      }
    },
