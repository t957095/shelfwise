      "method": "GET",
      "timeout": 10,
      "requires_auth": "EBAY_API_KEY",
      "extract": {
        "name": ["itemSummaries", 0, "title"],
        "brand": ["itemSummaries", 0, "brand"],
        "category": ["itemSummaries", 0, "category"],
        "description": ["itemSummaries", 0, "description"],
        "image_urls": ["itemSummaries", 0, "image"],
