{
  "description": "ShelfWise Scraper Registry - Configurable source definitions for UPC product lookup. Add new sources by adding entries to this file. Each entry defines a scraper that can extract product data from a specific API or website.",
  "version": "1.0",
  "sources": [
    {
      "name": "Open Food Facts",
      "type": "api",
      "weight": 0.90,
      "url_template": "https://world.openfoodfacts.org/api/v2/product/{upc}.json",
      "method": "GET",
      "timeout": 12,
      "extract": {
        "name": ["product", "product_name"],
        "brand": ["product", "brands"],
        "category": ["product", "categories"],
        "description": ["product", "generic_name"],
        "image_urls": ["product", "image_url"],
        "attributes": ["product", "nutriments"]
      },
      "success_condition": ["status", 1]
    },
    {
      "name": "UPCItemDB",
      "type": "api",
      "weight": 0.85,
      "url_template": "https://api.upcitemdb.com/prod/trial/lookup?upc={upc}",
      "method": "GET",
      "timeout": 12,
      "extract": {
        "name": ["items", 0, "title"],
        "brand": ["items", 0, "brand"],
        "category": ["items", 0, "category"],
        "description": ["items", 0, "description"],
        "image_urls": ["items", 0, "images"],
        "attributes": ["items", 0, "color"]
      }
    },
    {
      "name": "BarcodeLookup",
      "type": "html",
      "weight": 0.75,
      "url_template": "https://www.barcodelookup.com/{upc}",
      "method": "GET",
      "timeout": 12,
      "selectors": {
        "name": ["h1.product-name", "title"],
        "brand": ["span.product-brand"],
        "description": ["div.product-description"],
        "image_urls": ["img.product-image"],
        "attributes": ["table.product-details"]
      }
    },
    {
      "name": "Go-UPC",
      "type": "html",
      "weight": 0.70,
      "url_template": "https://go-upc.com/search?q={upc}",
      "method": "GET",
      "timeout": 12,
      "selectors": {
        "name": ["h1.product-name", "h1"],
        "brand": ["span.product-brand"],
        "description": ["div.product-description"],
        "image_urls": ["img.product-image"]
      }
    },
    {
