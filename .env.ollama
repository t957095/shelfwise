# ShelfWise Environment — Ollama (Local, Fully Offline)
# Install: https://ollama.com/download/windows
# Pull model: ollama pull llama3.1:8b
# No API key needed for local Ollama

FOUNDRY_ENDPOINT=http://localhost:11434/v1/chat/completions
FOUNDRY_API_KEY=ollama
FOUNDRY_MODEL=llama3.1:8b

DATABASE_URL=sqlite:///backend/shelfwise.db
