# Microsoft Foundry Integration (Optional)
# If not configured, ShelfWise uses deterministic fallback reasoning
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_MODEL=gpt-4

# Product discovery and image acquisition providers (Optional but recommended)
# These let ShelfWise search marketplace/store pages and image indexes when
# normal HTML scraping is blocked by anti-bot pages.
BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=
SERPAPI_KEY=
SEARCHAPI_KEY=
EBAY_BEARER_TOKEN=
AMAZON_SCRAPER_API_KEY=
RAPIDAPI_AMAZON_SCRAPER_KEY=
RAPIDAPI_KEY=
AMAZON_COUNTRY_CODE=US

# Runtime defaults
# Start each app launch with an empty local catalog. Set to false only for debugging.
SHELFWISE_CLEAR_ON_STARTUP=true
# Keep hardcoded demo fallback records out of normal enrichment.
SHELFWISE_ENABLE_DEMO_FALLBACK=false

# Database
DATABASE_URL=sqlite:///backend/shelfwise.db
