# Microsoft Foundry Integration (Optional)
# If not configured, ShelfWise uses deterministic fallback reasoning
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_MODEL=gpt-4

# Product discovery and image acquisition providers (Optional but recommended)
# These let ShelfWise search marketplace/store pages and image indexes when
# normal HTML scraping is blocked by anti-bot pages.
BRAVE_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=
SERPAPI_KEY=
SEARCHAPI_KEY=
EBAY_BEARER_TOKEN=

# Database
DATABASE_URL=sqlite:///backend/shelfwise.db
