# ShelfWise Environment — Microsoft Azure AI Foundry (Production)
# Create a Foundry project: https://ai.azure.com
# Deploy a model (gpt-4o, gpt-4o-mini, Phi-4, etc.)
# Copy the endpoint + key from the model deployment page

# Tier 1: Azure AI Inference SDK (azure-ai-inference)
FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/models/chat/completions
FOUNDRY_API_KEY=<your-azure-key>
FOUNDRY_MODEL=gpt-4o-mini

# Tier 2: Azure AI Projects Agent SDK (optional — for agent orchestration)
AZURE_FOUNDRY_CONNECTION_STRING=westus.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>

DATABASE_URL=sqlite:///backend/shelfwise.db